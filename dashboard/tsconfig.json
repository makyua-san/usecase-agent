{
  "compilerOptions": {
    "target": "ES2022",
    "module": "ESNext",
    "moduleResolution": "bundler",
    "jsx": "react-jsx",
    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "paths": {
      "@server/*": ["./server/*"],
      "@client/*": ["./client/*"]
    }
  },
  "include": ["server/**/*.ts", "client/**/*.tsx", "client/**/*.ts"]
}
