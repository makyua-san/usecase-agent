# Required
ANTHROPIC_API_KEY=sk-ant-...

# Optional: Webhook notification (Slack Incoming Webhook or Discord Webhook)
WEBHOOK_URL=
# WEBHOOK_TYPE=discord  # 'slack' or 'discord' (default: discord)

# Optional: Dashboard external access
# DOMAIN=your-domain.example.com

# Agent settings
# HARD_TIMEOUT_MS=1800000  # 30 minutes (default)
# RUN_INTERVAL: systemd timerで制御 (OnCalendar=*-*-* *:00:00)
# 変更する場合は scripts/usecase-agent-run.timer を直接編集
